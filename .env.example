# Copy to .env on the server and fill in real values (never commit .env)
DB_USER=secshare
DB_PASSWORD=change-me-strong-password
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-base64-secret

# Optional: bootstrap an admin account on first startup (leave blank to skip).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong-admin-password

# Optional: email delivery of per-recipient audience links. Leave MAIL_ENABLED=false to disable.
# Gmail example (requires 2-Step Verification + a 16-char App Password, NOT your normal password):
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=youraddress@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_FROM=youraddress@gmail.com
# Absolute public URL of the site, used to build links in emails (no trailing slash).
PUBLIC_BASE_URL=https://your-domain
